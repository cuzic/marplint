{
  "name": "marplint",
  "version": "1.0.0",
  "description": "Linter for Marp slides - detects overflow and whitespace issues",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "marplint": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "lint": "bun run src/index.ts",
    "check": "biome check ./src ./tests",
    "check:fix": "biome check ./src ./tests --write",
    "format": "biome format ./src ./tests --write",
    "test": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "playwright": "^1.48.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["marp", "linter", "markdown", "slides", "overflow"],
  "author": "",
  "license": "MIT"
}
