#!/bin/bash

# marplint pre-commit hook
# Install: cp marplint/scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "🔍 Running marplint..."

# Get list of staged markdown files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "✓ No markdown files to check"
  exit 0
fi

# Run marplint on staged files (static rules only for speed)
bun run marplint/src/index.ts --static $STAGED_FILES

RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo ""
  echo "❌ marplint found issues. Please fix them before committing."
  echo ""
  echo "To skip this check (not recommended):"
  echo "  git commit --no-verify"
  echo ""
  echo "To auto-fix some issues:"
  echo "  bun run marplint --fix $STAGED_FILES"
  exit 1
fi

echo "✅ marplint checks passed!"
exit 0
